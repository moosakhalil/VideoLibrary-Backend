# ---- Backend configuration ----
PORT=5000

# MongoDB connection string. Replace <db_password> with your real Atlas password.
# (URL-encode it if it contains special characters like @ : / ?)
MONGODB_URI=mongodb+srv://moosa:<db_password>@cluster0.xtd7hkl.mongodb.net/rewards?appName=Cluster0

# Secret used to sign/verify our own JWTs. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret-string
JWT_EXPIRES_IN=60d

# Where the React app is served from (for CORS + cookies)
CLIENT_ORIGIN=http://localhost:5173

# PIN rules
PIN_MIN_LENGTH=4
PIN_MAX_LENGTH=6

# Brute-force lock
MAX_PIN_ATTEMPTS=5
PIN_LOCK_MINUTES=15

# Set to "true" in production (HTTPS) so the auth cookie is Secure
COOKIE_SECURE=false

# ---- Admin panel credentials ----
ADMIN_USERNAME=admin12
ADMIN_PASSWORD=admin12

# ---- Construction integration (referrals + WhatsApp-status come from there) ----
# Base URL of the construction backend that owns referral/status progress.
CONSTRUCTION_API_URI=https://construction-project-backend-code.onrender.com/
# Shared secret sent as the x-api-key header. MUST match the construction side.
# Keep this only in the backend env — never expose it to the frontend.
WEB_API_KEY=fe6726239acecad4bb5718e6a8470d10bcd9311db2c5351517622f965e0c619f
